# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Environment: development | staging | production
NODE_ENV=development

# Backend server port
BACKEND_PORT=3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Composite PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database?schema=schema
# REQUIRED: Must be set for database operations
DATABASE_URL=postgresql://user:password@localhost:5432/action-architect?schema=public

# ============================================================================
# REDIS CONFIGURATION (for job queue)
# ============================================================================
# Redis host for job queue
# Default: localhost (for development)
REDIS_HOST=localhost

# Redis port for job queue
# Default: 6379 (standard Redis port)
REDIS_PORT=6379

# Redis password (optional, leave empty for local development)
# Only set if your Redis instance requires authentication
REDIS_PASSWORD=

# ============================================================================
# SERVER & COMMUNICATION CONFIGURATION
# ============================================================================
# Socket.IO Server URL (for worker-to-client notifications)
# Default: http://localhost:3000
SOCKET_SERVER_URL=http://localhost:3000

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Frontend origin for CORS policy
# Default: http://localhost:5173 (Vite default)
CORS_ORIGIN=http://localhost:5173

# Frontend API Base URL (used by client-side JavaScript)
# This must be a public URL accessible from the browser
# Default: http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT secret for signing authentication tokens
# REQUIRED: Must be at least 32 characters in production
# In development, use a simple string; change before deploying
JWT_SECRET=your-secret-key-here-min-32-chars

# Guest user credentials (for demo/testing purposes)
# Email for guest user account
GUEST_USER_EMAIL=guest@action-architect.local

# Name for guest user account
GUEST_USER_NAME=Guest User

# Password for guest user account (hashed with bcrypt before storage)
GUEST_USER_PASSWORD=guest-password

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
# LLM API Key (required for AI plan generation)
# REQUIRED: Must be set to enable AI features
LLM_API_KEY=sk-proj-your-api-key-here

# Primary LLM model for plan generation
# Default: deepseek-v4-pro
LLM_MODEL=deepseek-v4-pro

# Fallback LLM model if primary is unavailable or rate-limited
# Default: deepseek-v4-flash
LLM_FALLBACK_MODEL=deepseek-v4-flash

# LLM API URL (endpoint for LLM requests)
# Default: https://api.deepseek.com/ (replace with actual endpoint if different)
LLM_API_URL=https://api.deepseek.com/chat/completions