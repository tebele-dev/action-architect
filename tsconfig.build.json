{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "noEmitOnError": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/app.ts",
    "src/prisma.ts",
    "src/lib/**/*.ts",
    "src/services/**/*.ts",
    "src/middleware/**/*.ts",
    "src/workers/**/*.ts",
    "src/queues/**/*.ts",
    "src/routes/-*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
